# Database (github_statistics — same DB the main sync and dashboard use)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
# TLS is required by the stage/prod DB (require_secure_transport=ON). Only set
# to false against a local MySQL that doesn't enforce/support TLS.
DB_TLS_ENABLED=true

# GitHub classic PAT with ONLY the read:packages scope, owned by the bot
# account and SSO-authorized for each tracked org. Required: package discovery
# rejects anonymous calls and fine-grained PATs. The HTML count scraping needs
# no credentials.
GITHUB_PAT=

# Versions pages scraped per package (50 tagged versions per page).
# 3 pages = the ~150 newest tagged versions; older versions keep their
# last-recorded counts.
VERSION_PAGES_LIMIT=3
