# Database
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_MAX_OPEN_CONNS=
DB_MAX_IDLE_CONNS=
DB_CONN_MAX_LIFETIME_SECONDS=
# TLS is required by the stage/prod DB (require_secure_transport=ON). Only set
# to false against a local MySQL that doesn't enforce/support TLS.
DB_TLS_ENABLED=true

# Auth — set to false for local testing (skips JWT signature verification)
AUTH_JWKS_ENDPOINT=
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_TOKEN_VALIDATOR_ENABLED=false

# Comma-separated group names allowed to call admin endpoints
ADMIN_GROUPS=

# Comma-separated allowed CORS origins for local SPA development (e.g. http://localhost:3000).
# Leave empty in production — the Choreo gateway handles CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Server
PORT=:8080
